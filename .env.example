# Copy this file to .env and fill only the services you use.
# Do not commit or share your real .env.

# Material APIs
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Coverr API access may depend on your account/API availability.
# Leave empty if you are not using Coverr yet.
COVERR_API_KEY=

# MiniMax TTS
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Optional MiniMax defaults. Change after confirming available voices in your account.
MINIMAX_TTS_MODEL=speech-02-hd
MINIMAX_TTS_VOICE_ID=Chinese (Mandarin)_Warm_Girl
